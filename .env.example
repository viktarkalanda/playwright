# Copy this file to .env and fill in the values as needed.
# .env is git-ignored; .env.example is committed as documentation.

# -------------------------------------------------------------------
# Target environment
# -------------------------------------------------------------------

# Select the environment profile: prod | staging | local
# Determines the base URL if BASE_URL is not set explicitly.
# Default: prod
# ENV=prod

# -------------------------------------------------------------------
# SauceDemo (primary test application)
# -------------------------------------------------------------------

# Explicit base URL — overrides ENV-based lookup when set.
# Default: https://www.saucedemo.com/
BASE_URL=https://www.saucedemo.com/

# URLs for non-prod environments (used when ENV=staging or ENV=local).
# STAGING_BASE_URL=https://staging.saucedemo.com/
# LOCAL_BASE_URL=http://localhost:3000/

# Shared password for all SauceDemo test users (standard_user, problem_user, …).
# Default: secret_sauce  (public demo credentials — safe to keep as default)
SAUCE_PASSWORD=secret_sauce

# -------------------------------------------------------------------
# Second-shop / DemoBlaze (secondary test application)
# -------------------------------------------------------------------

# Base URL for the DemoBlaze site used by the second-shop tests.
# Default: https://www.demoblaze.com
SECOND_SHOP_BASE_URL=https://www.demoblaze.com

# -------------------------------------------------------------------
# CI / pipeline flags
# -------------------------------------------------------------------

# Set to any non-empty value in CI environments.
# Effects: enables forbidOnly, sets retries=2, limits workers=2.
# CI=true

# -------------------------------------------------------------------
# Anthropic / Claude API
# -------------------------------------------------------------------

# Anthropic API key. NEVER commit the real key to git.
# Locally: copy to .env and fill in your key.
# In Jenkins: Manage Jenkins → Credentials → Add → Secret text → ID: anthropic-api-key
# ANTHROPIC_API_KEY=sk-ant-xxxx
